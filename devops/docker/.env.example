# ─────────────────────────────────────────────────────────────
# MedVault Docker Compose — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and customize values.
# The .env file is git-ignored and used by docker compose automatically.
# ─────────────────────────────────────────────────────────────

# SQL Server
SQL_SA_PASSWORD=MedVault_Dev123!
SQL_PORT=1433

# JWT (CHANGE IN PRODUCTION)
JWT_KEY=DEV-ONLY-SECRET-KEY-CHANGE-IN-PRODUCTION-1234567890!

# Google OAuth
GOOGLE_CLIENT_ID=YOUR-GOOGLE-CLIENT-ID.apps.googleusercontent.com

# MedVault.API ports
API_PORT=5100
