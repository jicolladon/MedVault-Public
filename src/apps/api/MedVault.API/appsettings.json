{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:medvault-app.database.windows.net,1433;Initial Catalog=medvault-api;Persist Security Info=False;User ID=medvault-api;Password=T9v$Q2m!zL7@pX4#!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Jwt": {
    "Key": "CHANGE-THIS-TO-A-SECURE-KEY-AT-LEAST-32-CHARACTERS-LONG!",
    "Issuer": "MedVault.API",
    "Audience": "MedVault.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Google": {
    "ClientId": "{{GOOGLE_CLIENT_ID}}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/medvault-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "MedVault.API"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "*"
    ]
  },
  "Sharing": {
    "DemoModeEnabled": false,
    "PublicBaseUrl": ""
  },
  "PushNotifications": {
    "Enabled": true,
    "Provider": "FCM",
    "ProjectId": "{{FCM_PROJECT_ID}}",
    "ServiceAccountJson": "",
    "ServiceAccountFilePath": "{{FILE_PATH_TO_FCM_SERVICE_ACCOUNT_JSON}}",
    "AndroidChannelId": "medvault_alerts"
  },
  "Maintenance": {
    "ShareLinksCleanup": {
      "Enabled": true,
      "IntervalMinutes": 60,
      "BatchSize": 500
    }
  },
  "FeatureSettings": {
    "Sharing": {
      "EmergencySharingEnabled": true,
      "PhysicianSharingEnabled": true,
      "MaxSharingLinksPerUser": 5,
      "DefaultMaxDocumentsToShare": 10,
      "MinDocumentsToShareLimit": 0,
      "MaxDocumentsToShareLimit": 10,
      "MaxSharedDocumentBytes": 10485760
    },
    "Documents": {
      "DocumentExtractDataEnabled": true,
      "MaxFilesPerDocument": 5,
      "DemonstrationModeEnabled": true
    }
  },
  "DocumentExtraction": {
    "MaxTotalFileSizeBytes": 10485760,
    "ExternalTimeoutSeconds": 30,
    "AllowedMimeTypes": [
      "application/pdf",
      "image/jpeg",
      "image/png",
      "image/jpg",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "text/plain"
    ]
  },
  "DocIntelligence": {
    "AiProvider": {
      "Provider": "Ollama",
      "ModelId": "llama3.2",
      "ApiKey": null,
      "Endpoint": "http://localhost:11434",
      "DeploymentName": null,
      "Temperature": 0.1,
      "MaxTokens": 14096
    },
    "Ocr": {
      "TesseractDataPath": "./tessdata",
      "Language": "eng"
    }
  },
  "Azure": {
    "SignalR": {
      "Enabled": "true"
    }
  }
}