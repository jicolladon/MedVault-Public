  "version": "0.2.0",
  "configurations": [
    {
      "name": "MedVault-dev",
      "cwd": "${workspaceFolder}\\src\\apps\\mobile\\medvault",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "args": [
        "--dart-define=GOOGLE_CLIENT_ID=${env:GOOGLE_CLIENT_ID}",
        "--dart-define=API_BASE_URL=https://localhost:7200",
        "--dart-define=DOCUMENT_API_URL=https://localhost:7038",
        "--dart-define=APP_ENV=development",
        "--dart-define=FIREBASE_API_KEY=${env:FIREBASE_API_KEY}",
        "--dart-define=FIREBASE_APP_ID=${env:FIREBASE_APP_ID}",
        "--dart-define=FIREBASE_MESSAGING_SENDER_ID=${env:FIREBASE_MESSAGING_SENDER_ID}",
        "--dart-define=FIREBASE_PROJECT_ID=${env:FIREBASE_PROJECT_ID}",
        "--dart-define=FIREBASE_STORAGE_BUCKET=${env:FIREBASE_STORAGE_BUCKET}",
        "--dart-define=FIREBASE_IOS_BUNDLE_ID=${env:FIREBASE_IOS_BUNDLE_ID}"
      ]
    },
    {
      "name": "MedVault-demo",
      "cwd": "${workspaceFolder}\\src\\apps\\mobile\\medvault",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "args": [
        "--dart-define=GOOGLE_CLIENT_ID=${env:GOOGLE_CLIENT_ID}",
